# OpenTrader / OpenClaw Trader — 安装配置（复制为 install.env 后填写）
# 用法: ./install.sh --config config/install.env

# ========== 必填 ==========
DEEPSEEK_API_KEY=
SIM_TRADING_TOKEN=

# ========== 行情 API（妙想/东方财富，可与 LLM 不同）==========
MX_APIKEY=

# ========== 安装路径 ==========
INSTALL_DIR=~/.openclaw-trader
GATEWAY_PORT=18789
TZ=Asia/Shanghai

# ========== 飞书（可选，见 config/feishu.yaml）==========
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ACCOUNT_ID=sonicteam
FEISHU_DELIVERY_GROUP_ID=
FEISHU_REQUIRE_MENTION=false

# ========== Gateway ==========
# 留空则 install 自动生成
OPENCLAW_GATEWAY_TOKEN=

# ========== 镜像 ==========
TRADER_IMAGE=openclaw-trader:1.0.0
SKIP_DOCKER_BUILD=0

# ========== 代理（可选，见 config/advanced.yaml）==========
# HTTP_PROXY=
# HTTPS_PROXY=
