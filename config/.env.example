# OpenClaw Trader — 安装时由 install.sh 生成，请勿提交到 Git

# === 必填（一键安装仅询问这两项时可映射如下）===
# 大模型 API Key
DEEPSEEK_API_KEY=

# 妙想行情/资讯 API（东方财富）；若与上相同厂商请填写同一密钥或安装后改此项
MX_APIKEY=

# 模拟盘 Token（对接模拟柜台 / 券商仿真环境）
SIM_TRADING_TOKEN=

# === 自动生成 ===
OPENCLAW_HOME=/opt/openclaw-trader/data
OPENCLAW_GATEWAY_TOKEN=
TZ=Asia/Shanghai

# === 可选：飞书推送（不配置则 Cron 仅写本地 reports/）===
FEISHU_SONICTEAM_APP_ID=
FEISHU_SONICTEAM_APP_SECRET=

# === 可选：出站代理 ===
# HTTP_PROXY=
# HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,open.feishu.cn,.feishu.cn,.larksuite.com,.feishu.net
