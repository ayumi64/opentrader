# 高级配置（复制为 advanced.yaml，可选）

proxy:
  http: ""
  https: ""
  no_proxy: "localhost,127.0.0.1,open.feishu.cn,.feishu.cn,.larksuite.com,.feishu.net"

models:
  fallbacks: []          # 例: ["doubao/ep-xxx"]
  doubao_api_key_env: DOUBAO_API_KEY

tools:
  web_fetch_timeout_ms: 45000
  deny:
    - web_search
    - web_fetch

channels:
  telegram:
    enabled: false
    bot_token_env: TELEGRAM_BOT_TOKEN

logging:
  level: info
